{
  "name": "kiosk-pos-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor shell for Kiosk POS Android and iOS apps",
  "scripts": {
    "sync": "cap sync",
    "sync:android": "cap sync android",
    "sync:ios": "cap sync ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios",
    "build:android": "cap build android",
    "build:ios": "cap build ios",
    "copy": "cap copy",
    "config:prod": "node scripts/write-capacitor-config.mjs production",
    "config:dev": "node scripts/write-capacitor-config.mjs development",
    "config:local": "node scripts/write-capacitor-config.mjs local",
    "config:local:ios": "node scripts/write-capacitor-config.mjs local-ios",
    "assets:generate": "node scripts/generate-app-assets.mjs",
    "build:release": "node scripts/ensure-android-build.mjs release",
    "install:debug": "node scripts/ensure-android-build.mjs",
    "pod:install": "node scripts/ensure-ios-sync.mjs",
    "run:local": "npm run config:local && npm run sync:android && npm run install:debug",
    "run:local:ios": "npm run config:local:ios && npm run pod:install && npm run open:ios",
    "run:prod": "npm run config:prod && npm run sync:android && npm run install:debug",
    "run:prod:ios": "npm run config:prod && npm run pod:install && npm run open:ios"
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "^7.1.0",
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.1",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.4.2",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.5",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/local-notifications": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "capacitor-thermal-printer": "^0.2.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
